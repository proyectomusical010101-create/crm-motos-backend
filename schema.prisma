generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Rol {
  id          String    @id @default(uuid())
  nombre      String    @unique
  descripcion String?
  usuarios    Usuario[]

  @@map("roles")
}

model Usuario {
  id           String                 @id @default(uuid())
  email        String                 @unique
  passwordHash String                 @map("password_hash")
  nombre       String
  rolId        String                 @map("rol_id")
  sucursal     String                 @default("Matriz Norte")
  activo       Boolean                @default(true)
  creadoEn     DateTime               @default(now()) @map("creado_en")
  auditorias   Auditoria[]
  movimientos  MovimientoInventario[]
  rol          Rol                    @relation(fields: [rolId], references: [id])

  @@map("usuarios")
}

model Cliente {
  id              String          @id @default(uuid())
  nombreCompleto  String          @map("nombre_completo")
  telefono        String
  whatsapp        String?
  email           String?
  direccion       String?
  ciudad          String?
  estado          String?
  codigoPostal    String?         @map("codigo_postal")
  rfc             String?         @unique
  fechaRegistro   DateTime        @default(now()) @map("fecha_registro")
  observaciones   String?
  cotizaciones    Cotizacion[]
  garantias       Garantia[]
  motocicletas    Motocicleta[]
  ordenesServicio OrdenServicio[]

  @@map("clientes")
}

model Motocicleta {
  id                  String          @id @default(uuid())
  clienteId           String          @map("cliente_id")
  marca               String
  modelo              String
  anio                Int
  color               String
  vin                 String          @unique
  numeroMotor         String          @map("numero_motor")
  placas              String?
  kilometraje         Int
  fechaCompra         DateTime        @map("fecha_compra")
  distribuidorOrigen  String?         @map("distribuidor_origen")
  fechaGarantiaLimite DateTime        @map("fecha_garantia_limite")
  estadoGarantia      String          @default("ACTIVA") @map("estado_garantia")
  creadoEn            DateTime        @default(now()) @map("creado_en")
  garantias           Garantia[]
  cliente             Cliente         @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  ordenesServicio     OrdenServicio[]

  @@map("motocicletas")
}

model Tecnico {
  id              String          @id @default(uuid())
  nombre          String
  especialidad    String
  telefono        String?
  correo          String?
  fechaIngreso    DateTime        @default(now()) @map("fecha_ingreso")
  activo          Boolean         @default(true)
  ordenesServicio OrdenServicio[]

  @@map("tecnicos")
}

model Refaccion {
  id          String                 @id @default(uuid())
  codigo      String                 @unique
  descripcion String
  marca       String
  categoria   String
  ubicacion   String?
  existencia  Int
  stockMinimo Int                    @default(5) @map("stock_minimo")
  costo       Decimal                @db.Decimal(10, 2)
  precioVenta Decimal                @map("precio_venta") @db.Decimal(10, 2)
  proveedor   String?
  creadoEn    DateTime               @default(now()) @map("creado_en")
  movimientos MovimientoInventario[]
  ordenes     OrdenRefaccion[]

  @@map("refacciones")
}

model OrdenServicio {
  id                 String           @id @default(uuid())
  folio              String           @unique
  fechaIngreso       DateTime         @default(now()) @map("fecha_ingreso")
  clienteId          String           @map("cliente_id")
  motocicletaId      String           @map("motocicleta_id")
  kilometraje        Int
  tecnicoId          String           @map("tecnico_id")
  tipoServicio       String           @map("tipo_servicio")
  descripcionFalla   String           @map("descripcion_falla")
  diagnosticoTecnico String?          @map("diagnostico_tecnico")
  solucionAplicada   String?          @map("solucion_aplicada")
  firmaCliente       String?          @map("firma_cliente")
  fechaCompromiso    DateTime         @map("fecha_compromiso")
  fechaEntrega       DateTime?        @map("fecha_entrega")
  estado             String           @default("Recibido")
  costoTotal         Decimal          @default(0) @map("costo_total") @db.Decimal(10, 2)
  creadoEn           DateTime         @default(now()) @map("creado_en")
  cotizacionVehiculo String?          @map("cotizacion_vehiculo")
  cotizacionItems    String?          @map("cotizacion_items")
  fotografias        Fotografia[]
  garantias          Garantia[]
  refacciones        OrdenRefaccion[]
  cliente            Cliente          @relation(fields: [clienteId], references: [id])
  motocicleta        Motocicleta      @relation(fields: [motocicletaId], references: [id], onDelete: Cascade)
  tecnico            Tecnico          @relation(fields: [tecnicoId], references: [id])

  @@map("ordenes_servicio")
}

model OrdenRefaccion {
  ordenId        String        @map("orden_id")
  refaccionId    String        @map("refaccion_id")
  cantidad       Int
  precioUnitario Decimal       @map("precio_unitario") @db.Decimal(10, 2)
  orden          OrdenServicio @relation(fields: [ordenId], references: [id], onDelete: Cascade)
  refaccion      Refaccion     @relation(fields: [refaccionId], references: [id])

  @@id([ordenId, refaccionId])
  @@map("orden_refacciones")
}

model Garantia {
  id                  String        @id @default(uuid())
  numeroGarantia      String        @unique @map("numero_garantia")
  ordenServicioId     String        @map("orden_servicio_id")
  marca               String
  clienteId           String        @map("cliente_id")
  motocicletaId       String        @map("motocicleta_id")
  fechaCompra         DateTime      @map("fecha_compra")
  fechaReclamacion    DateTime      @default(now()) @map("fecha_reclamacion")
  componenteAfectado  String        @map("componente_afectado")
  descripcionProblema String        @map("descripcion_problema")
  dictamenTecnico     String?       @map("dictamen_tecnico")
  estado              String        @default("Capturada")
  costoCubierto       Decimal       @default(0) @map("costo_cubierto") @db.Decimal(10, 2)
  creadoEn            DateTime      @default(now()) @map("creado_en")
  fotografias         Fotografia[]
  cliente             Cliente       @relation(fields: [clienteId], references: [id])
  motocicleta         Motocicleta   @relation(fields: [motocicletaId], references: [id])
  orden               OrdenServicio @relation(fields: [ordenServicioId], references: [id])

  @@map("garantias")
}

model MovimientoInventario {
  id          String    @id @default(uuid())
  refaccionId String    @map("refaccion_id")
  tipo        String
  cantidad    Int
  motivo      String
  fecha       DateTime  @default(now())
  usuarioId   String    @map("usuario_id")
  refaccion   Refaccion @relation(fields: [refaccionId], references: [id], onDelete: Cascade)
  usuario     Usuario   @relation(fields: [usuarioId], references: [id])

  @@map("movimientos_inventario")
}

model Fotografia {
  id              String         @id @default(uuid())
  ordenServicioId String?        @map("orden_servicio_id")
  garantiasId     String?        @map("garantias_id")
  urlImagen       String         @map("url_imagen")
  tipo            String
  creadoEn        DateTime       @default(now()) @map("creado_en")
  garantias       Garantia?      @relation(fields: [garantiasId], references: [id], onDelete: Cascade)
  orden           OrdenServicio? @relation(fields: [ordenServicioId], references: [id], onDelete: Cascade)

  @@map("fotografias")
}

model Auditoria {
  id            String   @id @default(uuid())
  usuarioId     String   @map("usuario_id")
  accion        String
  tablaAfectada String   @map("tabla_afectada")
  registroId    String   @map("registro_id")
  detalles      String
  fecha         DateTime @default(now())
  usuario       Usuario  @relation(fields: [usuarioId], references: [id])

  @@map("auditoria_logs")
}

model Cotizacion {
  id                 String           @id @default(uuid())
  folio              String           @unique
  fecha              String
  clienteId          String           @map("cliente_id")
  vehiculo           String
  estado             String           @default("Pendiente")
  costoServicio      Decimal          @default(0) @map("costo_servicio") @db.Decimal(10, 2)
  costoRefacciones   Decimal          @default(0) @map("costo_refacciones") @db.Decimal(10, 2)
  costoTotal         Decimal          @default(0) @map("costo_total") @db.Decimal(10, 2)
  ordenServicioFolio String?          @map("orden_servicio_folio")
  creadoEn           DateTime         @default(now()) @map("creado_en")
  cotizacionItems    CotizacionItem[]
  cliente            Cliente          @relation(fields: [clienteId], references: [id], onDelete: Cascade)

  @@map("cotizaciones")
}

model CotizacionItem {
  id            String     @id @default(uuid())
  cotizacionId  String     @map("cotizacion_id")
  descripcion   String
  unidadMedida  String     @default("Pza") @map("unidad_medida")
  costo         Decimal    @default(0) @db.Decimal(10, 2)
  manoDeObra    Decimal    @default(0) @map("mano_de_obra") @db.Decimal(10, 2)
  tiempoEntrega String     @default("Inmediata") @map("tiempo_entrega")
  cotizacion    Cotizacion @relation(fields: [cotizacionId], references: [id], onDelete: Cascade)

  @@map("cotizacion_items")
}

model Activacion {
  id            String   @id @default(uuid())
  marca         String
  modelo        String
  tienda        String
  vin           String   @unique
  clienteNombre String   @map("cliente_nombre")
  placas        String?
  tecnicoNombre String   @map("tecnico_nombre")
  fecha         DateTime @default(now()) @map("fecha")
  estado        String   @default("Activado")

  @@map("activaciones")
}
